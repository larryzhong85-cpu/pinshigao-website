generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Category {
  id          Int       @id @default(autoincrement())
  nameZh      String
  nameEn      String
  nameDe      String
  slug        String    @unique
  image       String?
  order       Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  products    Product[]
}

model Product {
  id          Int       @id @default(autoincrement())
  slug        String    @unique
  nameZh      String
  nameEn      String
  nameDe      String
  subtitleZh  String?
  subtitleEn  String?
  subtitleDe  String?
  descZh      String?
  descEn      String?
  descDe      String?
  specsZh     String?
  specsEn     String?
  specsDe     String?
  images      String?   // JSON array of image filenames
  categoryId  Int?
  category    Category? @relation(fields: [categoryId], references: [id])
  featured    Boolean   @default(false)
  order       Int       @default(0)
  published   Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model News {
  id          Int       @id @default(autoincrement())
  slug        String    @unique
  titleZh     String
  titleEn     String
  titleDe     String
  summaryZh   String?
  summaryEn   String?
  summaryDe   String?
  contentZh   String?
  contentEn   String?
  contentDe   String?
  image       String?
  date        DateTime  @default(now())
  published   Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Page {
  id          Int       @id @default(autoincrement())
  slug        String    @unique
  titleZh     String
  titleEn     String
  titleDe     String
  contentZh   String?
  contentEn   String?
  contentDe   String?
  published   Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Setting {
  id    Int    @id @default(autoincrement())
  key   String @unique
  value String
}

model Media {
  id        Int      @id @default(autoincrement())
  filename  String
  original  String
  mimetype  String
  size      Int
  createdAt DateTime @default(now())
}
